# syntax=docker/dockerfile:1
# Use a modern Node image as the base
FROM node:24-bookworm-slim

# Label the image for easier filtering
LABEL org.nyx.sandbox="true"

# Install basic development tools
RUN apt-get update && apt-get install -y \
    git \
    tmux \
    curl \
    python3 \
    python3-pip \
    vim \
    bash \
    sudo \
    procps \
    && rm -rf /var/lib/apt/lists/*


# Configure pnpm environment
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

# Enable Corepack to use pnpm (Faster, better caching, more reliable than npm)
RUN corepack enable

# Configure pnpm for speed and resilience in poor network conditions
# - store-dir: Explicitly set store location for cache mounting
# - registry: Use Yarn mirror (https://registry.yarnpkg.com/) to bypass npm registry peering issues
# - fetch-retries: Be persistent against dropped packets
# - fetch-retry-maxtimeout: Fail fast (60s) rather than hanging for 10+ mins
# - network-concurrency: Limit connections to prevent choking the pipe
RUN pnpm config set store-dir /pnpm/store \
    && pnpm config set registry https://registry.yarnpkg.com/ \
    && pnpm config set fetch-retries 5 \
    && pnpm config set fetch-retry-maxtimeout 60000 \
    && pnpm config set network-concurrency 4

# Install the Gemini CLI
# METHOD: Use ADD to fetch version JSON first. This invalidates the cache ONLY when the upstream version changes.
# If version matches cache, the expensive 'pnpm add' step is skipped entirely.
ADD https://registry.yarnpkg.com/@google/gemini-cli/latest /tmp/gemini-version.json
RUN --mount=type=cache,target=/pnpm/store \
    pnpm add -g @google/gemini-cli

# Install Claude Code
ADD https://registry.yarnpkg.com/@anthropic-ai/claude-code/latest /tmp/claude-version.json
RUN --mount=type=cache,target=/pnpm/store \
    pnpm add -g @anthropic-ai/claude-code

# Install Pi Coding Agent
ADD https://registry.yarnpkg.com/@mariozechner/pi-coding-agent/latest /tmp/pi-version.json
RUN --mount=type=cache,target=/pnpm/store \
    pnpm add -g @mariozechner/pi-coding-agent

# Pre-configure Gemini CLI settings
RUN mkdir -p /root/.gemini && \
    echo '{"general": {"previewFeatures": true}, "security": {"auth": {"selectedType": "oauth-personal"}}}' > /root/.gemini/settings.json

# Pre-configure Pi agent settings
RUN mkdir -p /root/.pi/agent && \
    echo '{"providers": {"moonshot": {"baseUrl": "https://api.moonshot.ai/v1", "api": "openai-completions", "apiKey": "MOONSHOT_API_KEY", "authHeader": true, "models": [{"id": "kimi-k2.5", "name": "Kimi K2.5 (Multimodal)", "reasoning": true, "input": ["text", "image"], "contextWindow": 128000, "maxTokens": 16384, "compat": {"maxTokensField": "max_completion_tokens", "supportsDeveloperRole": false, "supportsUsageInStreaming": true}}, {"id": "kimi-k2-turbo-preview", "name": "Kimi K2 Turbo", "reasoning": false, "input": ["text"], "contextWindow": 128000, "maxTokens": 16384, "compat": {"maxTokensField": "max_completion_tokens", "supportsDeveloperRole": false}}]}}}' > /root/.pi/agent/models.json

# Set up a working directory
WORKDIR /workspace

# Copy and setup initialization script
COPY init_identity.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/init_identity.sh

# Entrypoint handles identity setup
ENTRYPOINT ["/usr/local/bin/init_identity.sh"]

# Default command: keep the container running
CMD ["tail", "-f", "/dev/null"]